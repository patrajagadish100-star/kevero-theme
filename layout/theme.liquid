<!-- layout/theme.liquid -->
<!DOCTYPE html>
<html>
<head>
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style>
    body { font-family: 'Poppins', sans-serif; margin:0; }
    header {position:sticky;top:0;background:#fff;display:flex;justify-content:space-between;padding:15px 30px;border-bottom:1px solid #eee;}
    .logo {font-size:24px;font-weight:bold;}
    nav a {margin-left:20px;text-decoration:none;color:#000;}
    .btn {background:#000;color:#fff;padding:12px 25px;border:none;border-radius:25px;}
  </style>
</head>
<body>

<header>
  <div>
    <div class="logo">Kevero</div>
    <div style="font-size:12px;color:#777;">Unique & Eye-Catching Finds</div>
  </div>
  <nav>
    <a href="/">Home</a>
    <a href="/collections/all">Shop</a>
  </nav>
</header>

{{ content_for_layout }}

<footer style="text-align:center;padding:20px;">
  © {{ shop.name }} - Kevero
</footer>

</body>
</html>


<!-- templates/index.liquid -->
<div style="text-align:center;padding:80px 20px;background:#f5f5f5;">
  <h1>Discover Unique Products</h1>
  <p>Trending & eye-catching items</p>
  <a href="/collections/all" class="btn">Shop Now</a>
</div>

<h2 style="text-align:center;margin:40px;">Trending Now 🔥</h2>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;padding:20px;">
  {% for product in collections.frontpage.products %}
  <div>
    <img src="{{ product.featured_image | img_url: 'medium' }}" style="width:100%;">
    <h3>{{ product.title }}</h3>
    <p>{{ product.price | money }}</p>
  </div>
  {% endfor %}
</div>


<!-- templates/product.liquid -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;padding:40px;">

  <div>
    <img src="{{ product.featured_image | img_url: 'large' }}" style="width:100%;">
  </div>

  <div>
    <span style="background:black;color:white;padding:5px 10px;">HOT</span>

    <h1>{{ product.title }}</h1>

    <p style="font-size:22px;color:red;">
      {{ product.price | money }}
      <span style="text-decoration:line-through;color:#888;">
        {{ product.compare_at_price | money }}
      </span>
    </p>

    <form method="post" action="/cart/add">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="btn" style="width:100%;margin-top:15px;">
        Add to Cart
      </button>
    </form>

    <p style="margin-top:15px;color:#555;">
      🚚 Fast Delivery | 🔒 Secure Payment | 💎 Premium Quality
    </p>

  </div>
</div>


<!-- config/settings_schema.json -->
[
  {"name":"Theme settings","settings":[]}
]
